generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FARMER
  BUYER
  AGGREGATOR
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum TransactionStatus {
  PENDING
  PAID
  ASSISTED
  CANCELLED
}

enum PaymentMethod {
  INTERSWITCH
  ASSISTED
}

enum NotificationChannel {
  SMS
  WHATSAPP
  IN_APP
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmer        Farmer?
  buyer         Buyer?
  aggregator    Aggregator?
  notifications Notification[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Farmer {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  farmName         String
  location         String
  cropTypes        String[]
  virtualAccountNo String?  @unique
  bankName         String?
  bankCode         String?
  totalEarned      Float    @default(0)
  walletBalance    Float    @default(0)
  registeredBy     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inventory    Inventory[]
  transactions Transaction[]
}

model Buyer {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model BuyerContact {
  id           String     @id @default(cuid())
  aggregatorId String
  aggregator   Aggregator @relation(fields: [aggregatorId], references: [id])
  name         String
  phone        String
  email        String?
  companyName  String?
  buyerId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  transactions Transaction[]

  @@unique([aggregatorId, phone])
}

model Aggregator {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  organizationName String
  commissionRate   Float    @default(1.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inventory     Inventory[]
  transactions  Transaction[]
  buyerContacts BuyerContact[]
}

model Inventory {
  id            String          @id @default(cuid())
  farmerId      String
  farmer        Farmer          @relation(fields: [farmerId], references: [id])
  addedById     String?
  aggregator    Aggregator?     @relation(fields: [addedById], references: [id])
  cropType      String
  quantity      Float
  pricePerKg    Float
  totalValue    Float
  status        InventoryStatus @default(AVAILABLE)
  notes         String?
  transactionId String?
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Transaction {
  id             String            @id @default(cuid())
  txnRef         String            @unique
  aggregatorId   String
  aggregator     Aggregator        @relation(fields: [aggregatorId], references: [id])
  farmerId       String
  farmer         Farmer            @relation(fields: [farmerId], references: [id])
  buyerId        String?
  buyer          Buyer?            @relation(fields: [buyerId], references: [id])
  buyerContactId String?
  buyerContact   BuyerContact?     @relation(fields: [buyerContactId], references: [id])
  cropType       String
  quantity       Float
  pricePerKg     Float
  totalAmount    Float
  platformFee    Float             @default(0)
  farmerReceives Float             @default(0)
  status         TransactionStatus @default(PENDING)
  paymentMethod  PaymentMethod?
  interswitchRef String?
  interswitchPay String?
  buyerNotified  Boolean           @default(false)
  paymentLink    String?
  notes          String?
  riskScore      String?   // LOW | MEDIUM | HIGH — from AI fraud check
  riskReason     String?   // AI explanation
  paidAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  receipt       Receipt?
  inventory     Inventory[]
  notifications Notification[]
}

model Receipt {
  id             String      @id @default(cuid())
  transactionId  String      @unique
  transaction    Transaction @relation(fields: [transactionId], references: [id])
  txnRef         String      @unique
  farmerName     String
  farmName       String
  buyerName      String
  cropType       String
  quantity       Float
  pricePerKg     Float
  totalAmount    Float
  platformFee    Float
  farmerReceives Float
  paymentMethod  String
  paidAt         DateTime
  createdAt      DateTime    @default(now())
}

model Notification {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  transactionId String?
  transaction   Transaction?        @relation(fields: [transactionId], references: [id])
  channel       NotificationChannel
  status        String              @default("SENT")
  message       String
  isRead        Boolean             @default(false)
  createdAt     DateTime            @default(now())
}
