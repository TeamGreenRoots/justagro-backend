{
  "info": {
    "name": "JustAgro API",
    "description": "Complete JustAgro API collection — Interswitch Hackathon 2024\n\n## Quick Start\n1. Register a farmer, buyer, and aggregator\n2. Login as farmer → copy token → set as `farmerToken` variable\n3. Login as buyer → copy token → set as `buyerToken` variable\n4. Run requests in order",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 1, "minor": 0, "patch": 0 }
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000", "type": "string" },
    { "key": "farmerToken",  "value": "",                      "type": "string" },
    { "key": "buyerToken",   "value": "",                      "type": "string" },
    { "key": "aggToken",     "value": "",                      "type": "string" },
    { "key": "farmerId",     "value": "",                      "type": "string" },
    { "key": "buyerId",      "value": "",                      "type": "string" },
    { "key": "deliveryId",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Verify the server is running"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — Farmer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.userId) pm.collectionVariables.set('farmerId', res.userId);",
                "pm.test('Status 201', () => pm.response.to.have.status(201));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Emeka Okafor\",\n  \"phone\": \"08012345678\",\n  \"password\": \"securepass123\",\n  \"role\": \"FARMER\",\n  \"farmName\": \"Emeka Rice Farm\",\n  \"location\": \"Kano State\",\n  \"cropTypes\": [\"Rice\", \"Maize\"]\n}"
            }
          }
        },
        {
          "name": "Register — Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AgroMart Nigeria\",\n  \"phone\": \"08087654321\",\n  \"password\": \"securepass123\",\n  \"role\": \"BUYER\",\n  \"companyName\": \"AgroMart Nigeria Ltd\"\n}"
            }
          }
        },
        {
          "name": "Register — Aggregator",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Platform Admin\",\n  \"phone\": \"08011112222\",\n  \"password\": \"admin123\",\n  \"role\": \"AGGREGATOR\",\n  \"organizationName\": \"JustAgro HQ\"\n}"
            }
          }
        },
        {
          "name": "Login — Farmer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.accessToken) pm.collectionVariables.set('farmerToken', res.accessToken);",
                "pm.test('Has access token', () => pm.expect(res.accessToken).to.be.a('string'));",
                "pm.test('Role is FARMER', () => pm.expect(res.user.role).to.equal('FARMER'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"08012345678\",\n  \"password\": \"securepass123\"\n}"
            }
          }
        },
        {
          "name": "Login — Buyer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.accessToken) pm.collectionVariables.set('buyerToken', res.accessToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"08087654321\",\n  \"password\": \"securepass123\"\n}"
            }
          }
        },
        {
          "name": "Login — Aggregator",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.accessToken) pm.collectionVariables.set('aggToken', res.accessToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"08011112222\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Farmer",
      "item": [
        {
          "name": "Farmer Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/farmer/dashboard",
            "description": "Get wallet, credit score, loans, deliveries"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{farmerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/farmer/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmName\": \"Emeka Premium Farm\",\n  \"location\": \"Kano State\",\n  \"cropTypes\": [\"Rice\", \"Maize\", \"Sorghum\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Buyer",
      "item": [
        {
          "name": "Buyer Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/v1/buyer/dashboard"
          }
        }
      ]
    },
    {
      "name": "Aggregator",
      "item": [
        {
          "name": "Aggregator Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": "{{baseUrl}}/api/v1/aggregator/dashboard"
          }
        }
      ]
    },
    {
      "name": "Deliveries",
      "item": [
        {
          "name": "Create Delivery",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.delivery?.id) pm.collectionVariables.set('deliveryId', res.delivery.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{aggToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/deliveries",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmerId\": \"{{farmerId}}\",\n  \"buyerId\": \"{{buyerId}}\",\n  \"productName\": \"Maize\",\n  \"quantity\": 500,\n  \"pricePerKg\": 180\n}"
            }
          }
        },
        {
          "name": "List Pending Deliveries (Buyer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deliveries?tab=pending",
              "query": [{ "key": "tab", "value": "pending" }]
            }
          }
        },
        {
          "name": "List Payment History (Buyer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deliveries?tab=history",
              "query": [{ "key": "tab", "value": "history" }]
            }
          }
        },
        {
          "name": "Get Single Delivery",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/v1/deliveries/{{deliveryId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate Payment (Confirm & Pay)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "pm.test('Has payment URL', () => pm.expect(res.paymentUrl).to.be.a('string'));",
                "if (res.reference) pm.collectionVariables.set('paymentRef', res.reference);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/v1/deliveries/{{deliveryId}}/pay",
            "description": "Returns Interswitch payment URL. Open URL to complete payment."
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/deliveries/{{deliveryId}}/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{paymentRef}}\",\n  \"paymentMethod\": \"CARD\"\n}"
            },
            "description": "Confirm payment → generates receipt, updates score, sends SMS"
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "Get Loan History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/loans"
          }
        },
        {
          "name": "Apply for Loan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{farmerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/loans",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Receipts",
      "item": [
        {
          "name": "Get Receipt (+ WhatsApp URL)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/receipts/{{deliveryId}}",
            "description": "Returns receipt data and a pre-filled WhatsApp share link"
          }
        }
      ]
    },
    {
      "name": "AI Features",
      "item": [
        {
          "name": "AI Credit Score Explainer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/ai/score-explain",
            "description": "Gemini AI explains your score and gives specific tips (FREE)"
          }
        },
        {
          "name": "AI Fraud Detection",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": "{{baseUrl}}/api/v1/ai/fraud-check/{{deliveryId}}",
            "description": "Analyzes delivery for fraud risk — LOW/MEDIUM/HIGH"
          }
        },
        {
          "name": "AI Price Intelligence",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/ai/price-intelligence/{{deliveryId}}",
            "description": "Compares delivery price to market rate, tells farmer if underpaid"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/notifications"
          }
        },
        {
          "name": "Get Unread Only",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications?unread=true",
              "query": [{ "key": "unread", "value": "true" }]
            }
          }
        }
      ]
    }
  ]
}
