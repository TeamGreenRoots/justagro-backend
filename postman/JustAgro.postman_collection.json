{
  "info": {
    "name": "JustAgro API v1",
    "description": "Complete JustAgro API v1 — full flow from registration to payment verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000", "type": "string" },
    { "key": "aggToken",     "value": "", "type": "string" },
    { "key": "farmerToken",  "value": "", "type": "string" },
    { "key": "buyerToken",   "value": "", "type": "string" },
    { "key": "farmerId",     "value": "", "type": "string" },
    { "key": "inventoryId",  "value": "", "type": "string" },
    { "key": "txnId",        "value": "", "type": "string" },
    { "key": "txnRef",       "value": "", "type": "string" },
    { "key": "contactId",    "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [{
        "name": "Health Check",
        "request": { "method": "GET", "url": "{{baseUrl}}/health" }
      }]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — Aggregator",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"JustAgro Admin\",\n  \"phone\": \"08000000001\",\n  \"password\": \"demo1234\",\n  \"role\": \"AGGREGATOR\",\n  \"organizationName\": \"JustAgro HQ\"\n}" }
          }
        },
        {
          "name": "Register — Farmer (Self)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Emeka Okafor\",\n  \"phone\": \"08000000002\",\n  \"password\": \"demo1234\",\n  \"role\": \"FARMER\",\n  \"farmName\": \"Emeka Rice Farm\",\n  \"location\": \"Kano State\",\n  \"cropTypes\": [\"Rice\", \"Maize\"]\n}" }
          }
        },
        {
          "name": "Login — Aggregator",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.accessToken) pm.collectionVariables.set('aggToken', r.accessToken);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"08000000001\",\n  \"password\": \"demo1234\"\n}" }
          }
        },
        {
          "name": "Login — Farmer",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.accessToken) pm.collectionVariables.set('farmerToken', r.accessToken);", "if (r.user?.farmerId) pm.collectionVariables.set('farmerId', r.user.farmerId);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"08000000002\",\n  \"password\": \"demo1234\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Farmer",
      "item": [
        {
          "name": "Farmer Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/farmer/dashboard/me"
          }
        },
        {
          "name": "Update Farm Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/farmer/profile/me",
            "body": { "mode": "raw", "raw": "{\n  \"farmName\": \"Emeka Premium Farm\",\n  \"location\": \"Kano State\",\n  \"cropTypes\": [\"Rice\", \"Maize\", \"Sorghum\"]\n}" }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Farmer Adds Own Stock",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.data?.id) pm.collectionVariables.set('inventoryId', r.data.id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/inventory",
            "body": { "mode": "raw", "raw": "{\n  \"cropType\": \"Maize\",\n  \"quantity\": 500,\n  \"pricePerKg\": 180,\n  \"notes\": \"Grade A, freshly harvested\"\n}" }
          }
        },
        {
          "name": "Aggregator Adds Stock for Farmer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/inventory",
            "body": { "mode": "raw", "raw": "{\n  \"farmerId\": \"{{farmerId}}\",\n  \"cropType\": \"Rice\",\n  \"quantity\": 1000,\n  \"pricePerKg\": 550,\n  \"notes\": \"Freshly harvested, Grade A\"\n}" }
          }
        },
        {
          "name": "List All Inventory (Aggregator)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/inventory?status=AVAILABLE&page=1&limit=10", "query": [{ "key": "status", "value": "AVAILABLE" }, { "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "List My Inventory (Farmer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/inventory"
          }
        },
        {
          "name": "Edit Inventory Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/inventory/{{inventoryId}}",
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 450,\n  \"pricePerKg\": 190\n}" }
          }
        },
        {
          "name": "Delete Inventory Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/inventory/{{inventoryId}}"
          }
        }
      ]
    },
    {
      "name": "Buyer Contacts",
      "item": [
        {
          "name": "List Buyer Contacts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": "{{baseUrl}}/api/v1/buyer-contacts"
          }
        },
        {
          "name": "Add Buyer Contact",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.data?.id) pm.collectionVariables.set('contactId', r.data.id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/buyer-contacts",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Abubakar Grains Store\",\n  \"phone\": \"08012345678\",\n  \"companyName\": \"Abubakar & Sons Ltd\",\n  \"email\": \"abubakar@grains.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.data?.id) pm.collectionVariables.set('txnId', r.data.id);", "if (r.data?.txnRef) pm.collectionVariables.set('txnRef', r.data.txnRef);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/transactions",
            "body": { "mode": "raw", "raw": "{\n  \"farmerId\": \"{{farmerId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"cropType\": \"Maize\",\n  \"quantity\": 200,\n  \"pricePerKg\": 180,\n  \"buyerContactId\": \"{{contactId}}\"\n}" }
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/transactions?page=1&limit=10", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Get Public Transaction (Payment Page)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/transactions/public/{{txnRef}}",
            "description": "No auth needed — this is what buyer opens from the payment link"
          }
        },
        {
          "name": "Verify Payment (After Interswitch)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/transactions/public/{{txnRef}}/verify",
            "body": { "mode": "raw", "raw": "{\n  \"resp\": \"00\"\n}" }
          }
        },
        {
          "name": "Mark as Paid (Assisted — no smartphone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/transactions/{{txnId}}/assist",
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Cash paid in person at farm gate\"\n}" }
          }
        },
        {
          "name": "Edit Transaction (PENDING only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/transactions/{{txnId}}",
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 250,\n  \"pricePerKg\": 185\n}" }
          }
        },
        {
          "name": "Cancel Transaction",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": "{{baseUrl}}/api/v1/transactions/{{txnId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Aggregator",
      "item": [
        {
          "name": "Aggregator Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": "{{baseUrl}}/api/v1/aggregator/dashboard"
          }
        },
        {
          "name": "Register Offline Farmer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/aggregator/register-farmer",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bello Yusuf\",\n  \"phone\": \"08055443322\",\n  \"farmName\": \"Bello Sorghum Farm\",\n  \"location\": \"Niger State\",\n  \"cropTypes\": [\"Sorghum\", \"Millet\"]\n}" }
          }
        },
        {
          "name": "List All Farmers (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{aggToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/farmers?page=1&limit=10", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/notifications"
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{farmerToken}}" }],
            "url": "{{baseUrl}}/api/v1/notifications/read-all"
          }
        }
      ]
    }
  ]
}
